{
  "name": "ui-spec-editor-front",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "concurrently --kill-others --names vite,wrangler \"vite build --watch\" \"wrangler dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy:dev": "bun run build && wrangler deploy --env dev",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "@fontsource/noto-sans-jp": "^5.2.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260425.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^4.0.18",
    "wrangler": "^4.72.0"
  }
}
